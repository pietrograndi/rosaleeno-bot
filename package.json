{
  "name": "vdg-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter telegram-gateway dev",
    "dev:rss": "pnpm --filter rss-watcher dev",
